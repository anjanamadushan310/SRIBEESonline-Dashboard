# SRIBEES Admin Dashboard Environment Variables

# API Configuration
# Dev: same-origin path proxied by Vite to the FastAPI backend (port 8000).
# Prod: full backend origin, e.g. https://api.sribees.lk/api/v1
VITE_API_URL=/api/v1
VITE_APP_NAME=SRIBEES Admin

# Feature Flags
VITE_ENABLE_MOCK_DATA=false
VITE_ENABLE_DEV_TOOLS=true
